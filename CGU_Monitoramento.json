    {
      "parameters": {
        "jsCode": "const devices = $node[\"GetUbiquitiDevices1\"].json.data;\nconst clientes = $('Pegar Clientes Tiflux').all().map(i => i.json);\n\nconst correcao_nomes = {\n  \"Nakayoshi\":                        \"Loja Nakayoshi\",\n  \"UCG Ultra - Antares\":              \"Antares Ambiental\",\n  \"UCG Ultra - Arquitetura Kids\":     \"Arquitetura Kids\",\n  \"UCG Ultra - CDias (Galpão 1)\":     \"CDias Engenharia\",\n  \"UCG Ultra - CDias (Galpão 2)\":     \"CDias Engenharia\",\n  \"UCG Ultra - CDias (Galpão 3)\":     \"CDias Engenharia\",\n  \"UCG Ultra - Centerbor\":            \"Centerbor\",\n  \"UCG Ultra - Centerplast\":          \"Centerplast\",\n  \"UCG Ultra - CFS\":                  \"CFS do Brasil\",\n  \"UCG Ultra - COPI Gestão\":          \"Copi Gestao Empresarial Ltda\",\n  \"UCG Ultra - Grupo AL2\":            \"Grupo AL2\",\n  \"UCG Ultra - HOMOLOGACAO\":          \"iTease Soluções em TI\",\n  \"UCG Ultra - iTease\":               \"iTease Soluções em TI\",\n  \"UCG Ultra - iTease DC\":            \"iTease Soluções em TI\",\n  \"UCG Ultra - Lógica Empreendiment\": \"Lógica Empreendimentos\",\n  \"UCG Ultra - M1 Tecnologia\":        \"M1 Tecnologia\",\n  \"UCG Ultra - Megaplasma\":           \"Megaplasma\",\n  \"UCG Ultra - Pecht Contabil\":       \"Pecht Contábil\",\n  \"UCG Ultra - Reinaflex (Filial)\":   \"Reinaflex\",\n  \"UCG Ultra - Reinaflex (Matriz)\":   \"Reinaflex\",\n  \"UCG Ultra - Samba Workspaces\":     \"Samba Workspaces\",\n  \"UCG Ultra - São Paulo 2\":          \"LONGITUDE\",\n  \"UCG Ultra - Urban Square\":         \"Urban Square\",\n  \"UCG Ultra - Vidraçaria São Luiz\":  \"Vidraçaria São Luis\",\n  \"UCG Ultra - Ville de Provence\":    \"Ville de Provence\",\n  \"UCG Ultra - Voilap\":               \"VOILAP BRASIL\",\n  \"UCG Ultra - Woodward\":             \"WoodWard\",\n  \"UCG Ultra - Atiara/Atiluz\":        \"Atiara\",\n  \"UCG Ultra - VisoFlex\":             \"Visoflex\",\n  \"UniFi Controller - Lógica Contabilidade\": \"Logica Contabilidade\",\n  \"UDM  - Amizade (Sumaré)\":          \"LONGITUDE\",\n  \"UDM  - Trend\":                     \"LONGITUDE\",\n  \"UDM - 1° Andar (Indaiatuba)\":      \"LONGITUDE\",\n  \"UDM - ELEV\":                       \"LONGITUDE\",\n  \"UDM - Itaim - Vibe - Zen\":         \"LONGITUDE\",\n  \"UDM - Logica Contabilidade\":       \"Logica Contabilidade\",\n  \"UDM - Longitude Matriz\":           \"LONGITUDE\",\n  \"UDM - Orion - Piracicaba\":         \"LONGITUDE\",\n  \"UDM - PDV Central (São Paulo)\":    \"LONGITUDE\",\n  \"UDM - Solis\":                      \"LONGITUDE\",\n  \"UDM - Sorocaba II\":                \"LONGITUDE\",\n  \"UDM - Villa Home Resort\":          \"LONGITUDE\",\n};\n\nconst excecoes_email = {\n  \"Nakayoshi\":                        \"nakayoshi\",\n  \"UCG Ultra - Antares\":              \"antares\",\n  \"UCG Ultra - Arquitetura Kids\":     \"arquiteturakids\",\n  \"UCG Ultra - CDias (Galpão 1)\":     \"cdias\",\n  \"UCG Ultra - CDias (Galpão 2)\":     \"cdias\",\n  \"UCG Ultra - CDias (Galpão 3)\":     \"cdias\",\n  \"UCG Ultra - Centerbor\":            \"centerbor\",\n  \"UCG Ultra - Centerplast\":          \"centerplast\",\n  \"UCG Ultra - CFS\":                  \"cfsdobrasil\",\n  \"UCG Ultra - COPI Gestão\":          \"copi\",\n  \"UCG Ultra - Grupo AL2\":            \"grupoal2\",\n  \"UCG Ultra - HOMOLOGACAO\":          \"itease\",\n  \"UCG Ultra - iTease\":               \"itease\",\n  \"UCG Ultra - iTease DC\":            \"itease\",\n  \"UCG Ultra - Lógica Empreendiment\": \"logicaempreendimentos\",\n  \"UniFi Controller - Lógica Contabilidade\": \"logica\",\n  \"UCG Ultra - M1 Tecnologia\":        \"m1\",\n  \"UCG Ultra - Megaplasma\":           \"megaplasma\",\n  \"UCG Ultra - Pecht Contabil\":       \"pechtcontabil\",\n  \"UCG Ultra - Reinaflex (Filial)\":   \"reinaflex\",\n  \"UCG Ultra - Reinaflex (Matriz)\":   \"reinaflex\",\n  \"UCG Ultra - Samba Workspaces\":     \"sambaworkspaces\",\n  \"UCG Ultra - São Paulo 2\":          \"longitude\",\n  \"UCG Ultra - Urban Square\":         \"urbansquare\",\n  \"UCG Ultra - Vidraçaria São Luiz\":  \"vidracaria\",\n  \"UCG Ultra - Ville de Provence\":    \"villedeprovence\",\n  \"UCG Ultra - Voilap\":               \"voilap\",\n  \"UCG Ultra - Woodward\":             \"woodward\",\n  \"UCG Ultra - Atiara/Atiluz\":        \"atiara\",\n  \"UCG Ultra - VisoFlex\":             \"visoflex\",\n  \"UDM  - Amizade (Sumaré)\":          \"longitude\",\n  \"UDM  - Trend\":                     \"longitude\",\n  \"UDM - 1° Andar (Indaiatuba)\":      \"longitude\",\n  \"UDM - ELEV\":                       \"longitude\",\n  \"UDM - Itaim - Vibe - Zen\":         \"longitude\",\n  \"UDM - Logica Contabilidade\":       \"logica\",\n  \"UDM - Longitude Matriz\":           \"longitude\",\n  \"UDM - Orion - Piracicaba\":         \"longitude\",\n  \"UDM - PDV Central (São Paulo)\":    \"longitude\",\n  \"UDM - Solis\":                      \"longitude\",\n  \"UDM - Sorocaba II\":                \"longitude\",\n  \"UDM - Villa Home Resort\":          \"longitude\",\n};\n\nfunction limpar(texto) {\n  if (!texto) return '';\n  return texto.toString().toLowerCase()\n    .replace(/&/g, 'e')\n    .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[\\s\\-\\._]/g, '');\n}\n\nreturn devices.map(device => {\n  const nomeCompleto = device.reportedState.name;\n\n  const nomeBusca = correcao_nomes[nomeCompleto] || nomeCompleto;\n  const nomeAlvoLimpo = limpar(nomeBusca);\n\n  let cliente = clientes.find(c => limpar(c.name) === nomeAlvoLimpo);\n  if (!cliente) {\n    cliente = clientes.find(c => {\n      const n = limpar(c.name);\n      return n.includes(nomeAlvoLimpo) || nomeAlvoLimpo.includes(n);\n    });\n  }\n\n  const apelido = excecoes_email[nomeCompleto] || limpar(nomeCompleto);\n  const emailSolicitante = `rmm.${apelido}@itease.com.br`;\n\n  return {\n    json: {\n      device_id:         device.id,\n      nome:              nomeCompleto,\n      status:            device.reportedState.state,\n      client_id:         cliente ? Number(cliente.id) : null,\n      client_name:       cliente ? cliente.name : null,\n      email_solicitante: emailSolicitante,\n    }\n  };\n});"
      },
