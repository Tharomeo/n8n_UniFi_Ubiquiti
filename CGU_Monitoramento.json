    {
      "parameters": {
        "jsCode": "const emailAlvo = $('Loop Over Items1').first().json.email_solicitante;\n\n// O HTTP node retorna o array inteiro como items[0].json\nconst lista = Array.isArray(items[0].json) ? items[0].json : items.map(i => i.json);\n\nconst usuario = lista.find(u =>\n  u.email && u.email.toLowerCase().trim() === emailAlvo.toLowerCase().trim()\n);\n\nif (usuario) {\n  return [{ json: { ...usuario } }];\n} else {\n  return [{ json: { erro: 'SOLICITANTE_NAO_ENCONTRADO', email_tentado: emailAlvo } }];\n}"
      },
