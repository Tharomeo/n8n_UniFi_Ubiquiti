    {
      "parameters": {
        "jsCode": "const dadosDevice = $('Loop Over Items1').first().json;\nconst registro = $('Verifica Restauracao1').first().json;\n\nconst ticketNumber = registro.Ticket; // campo correto no Baserow\n\nif (!ticketNumber) return [];\n\nconst dataAgora = new Date().toLocaleDateString('pt-BR', {\n  timeZone: 'America/Sao_Paulo',\n  year: 'numeric', month: '2-digit', day: '2-digit'\n}).split('/').reverse().join('-');\n\nreturn [{\n  json: {\n    ...dadosDevice,\n    ticket_number:         ticketNumber,\n    apontamento_date:      dataAgora,\n    descricao_apontamento: `Dispositivo ${dadosDevice.nome} restabeleceu conexão com a Ubiquiti.`,\n  }\n}];"
      },
