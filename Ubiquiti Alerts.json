              "name": "tituloChamado",
              "value": "=✅ Sinal Restaurado: {{ $json.device_name }} está ONLINE!",
              "type": "string"
            },
            {
              "id": "ccccb415-b2da-4c13-ad11-717a96ca9ae8",
              "name": "descricaoChamado",
              "value": "=<div style=\"font-family: Arial, sans-serif; padding: 25px; border: 1px solid #e0e0e0; border-radius: 8px; max-width: 600px; margin: auto; background-color: #f0fff0;\">\n   \n   <h2 style=\"color: #27ae60; border-bottom: 2px solid #27ae60; padding-bottom: 10px;\">\n     👍 Notificação de Restauração\n     <img src=\"https://i.imgur.com/t0K9ER0.png\" style=\"float: right; height: 40px; margin-top: -5px;\" alt=\"Logo\">\n   </h2>\n   \n   <p>Boas notícias! O dispositivo <strong>{{ $json.device_name }}</strong> está online novamente.</p>\n   \n   <div style=\"background-color: #ffffff; border: 1px solid #dddddd; padding: 15px; border-radius: 5px; margin-top: 15px;\">\n      <p style=\"margin: 5px 0;\"><strong>ID do Dispositivo:</strong> {{ $json.device_id }}</p>\n      <p style=\"margin: 5px 0;\"><strong>Horário da Detecção:</strong> {{ new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }) }}</p>\n   </div>\n</div>",
