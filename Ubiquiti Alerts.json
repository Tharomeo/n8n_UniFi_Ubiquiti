    {
      "parameters": {
        "jsCode": "// 1. Inicializa as variáveis de tempo\nconst startTime = new Date($('Decide Restauracao').first().json.created_at);\nconst endTime = new Date(); // Data e hora atual\n\nlet durationMinutes = 0; // Inicializa com 0\nlet diffMs = null;\n\n// 2. Verifica se a data de início é válida antes de calcular\n// A forma mais segura de verificar a validade de um objeto Date é checar se getTime() não é NaN\nif (!isNaN(startTime.getTime())) {\n    diffMs = endTime - startTime; // Diferença em milissegundos\n    // Math.round para garantir que a duração seja um número inteiro (como na sua tabela SQL)\n    durationMinutes = Math.round(diffMs / (1000 * 60)); \n} \n// Se a data for inválida, durationMinutes permanece 0.\n\n// 3. Adiciona os novos campos ao item atual\n$json.end_time = endTime.toISOString();\n$json.duration_minutes = durationMinutes;\n\nreturn $json;\n"
      },
      "type": "n8n-nodes-base.code",
